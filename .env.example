# Threads OAuth (required for one-click connect)
THREADS_APP_ID=your_meta_app_id
THREADS_APP_SECRET=your_meta_app_secret
THREADS_REDIRECT_URI=http://localhost:5000/api/auth/threads/callback

# AI Provider Keys (server-side - users won't need own keys)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
GOOGLE_AI_API_KEY=your_google_ai_key

# Giphy API (for GIF search in composer)
VITE_GIPHY_KEY=your_giphy_api_key

# Admin
ADMIN_EMAIL=your@email.com
